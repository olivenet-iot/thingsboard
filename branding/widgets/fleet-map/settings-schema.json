{
  "schema": {
    "type": "object",
    "title": "Fleet Map Settings",
    "properties": {
      "onlineThresholdMinutes": {
        "title": "Online threshold (minutes)",
        "type": "number",
        "default": 10
      },
      "standardDashboardId": {
        "title": "Standard (DALI2) Dashboard ID",
        "type": "string",
        "default": ""
      },
      "plusDashboardId": {
        "title": "Plus (D4i) Dashboard ID",
        "type": "string",
        "default": ""
      },
      "defaultTier": {
        "title": "Default tier when attribute is missing",
        "type": "string",
        "default": "standard"
      }
    }
  },
  "form": [
    {"key": "onlineThresholdMinutes", "type": "number", "placeholder": "10"},
    {"key": "standardDashboardId", "type": "text", "placeholder": "Dashboard ID for Standard (DALI2) sites"},
    {"key": "plusDashboardId", "type": "text", "placeholder": "Dashboard ID for Plus (D4i) sites"},
    {"key": "defaultTier", "type": "text", "placeholder": "standard"}
  ]
}
