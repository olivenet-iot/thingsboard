# SignConnect Brand Configuration
# Copy this file and customize for your brand

# ============================================
# BRAND IDENTITY
# ============================================

# Brand name (replaces "ThingsBoard" in UI)
BRAND_NAME="SignConnect"

# Company name (for copyright)
BRAND_COMPANY="Lumosoft"

# Domain (for any URL references)
BRAND_DOMAIN="signconnect.io"

# ============================================
# COLOR PALETTE
# ============================================
# All colors in hex format WITHOUT the # prefix

# Primary brand color (main UI color)
# Original ThingsBoard: 305680
PRIMARY_COLOR="305680"

# Secondary color (lighter shade)
# Original ThingsBoard: 527dad
SECONDARY_COLOR="527dad"

# Accent color (very light, highlights)
# Original ThingsBoard: a7c1de
ACCENT_COLOR="a7c1de"

# Dark mode primary
# Original ThingsBoard: 9fa8da
DARK_PRIMARY_COLOR="9fa8da"

# Light primary (hover states)
# Original ThingsBoard: 7986cb
LIGHT_PRIMARY_COLOR="7986cb"

# Loading spinner color (RGB format)
# Original ThingsBoard: 43,160,199
LOADING_SPINNER_COLOR="43,160,199"

# ============================================
# COPYRIGHT & LEGAL
# ============================================

# Copyright holder name
COPYRIGHT_HOLDER="Lumosoft"

# Full copyright text ({year} will be replaced with current year)
COPYRIGHT_TEXT="Copyright © {year} Lumosoft"

# ============================================
# DOCUMENTATION
# ============================================

# Help/documentation base URL
# Leave empty to disable help links entirely
# Example: "https://docs.signconnect.io"
DOCS_URL=""

# ============================================
# DOCKER CONFIGURATION
# ============================================

# Docker registry URL (without trailing slash)
DOCKER_REGISTRY=""

# Docker repository/organization name
DOCKER_REPO="signconnect"

# Image tag (usually version)
DOCKER_TAG="latest"

# ============================================
# EMAIL TEMPLATES
# ============================================

# Email sender name
EMAIL_SENDER_NAME="SignConnect"

# Email signature
EMAIL_SIGNATURE="— The SignConnect Team"

# Email footer text
EMAIL_FOOTER="by Lumosoft"

# ============================================
# TRANSLATION SETTINGS
# ============================================

# Update all translation files (27 languages)
# Set to "false" to only update English
UPDATE_ALL_TRANSLATIONS="true"

# ============================================
# ADVANCED OPTIONS
# ============================================

# Create backup before modifying files
CREATE_BACKUP="true"

# Backup directory (relative to branding/)
BACKUP_DIR="originals"

# Remove help links entirely (vs pointing to custom docs)
REMOVE_HELP_LINKS="true"

# Verbose logging during script execution
VERBOSE="false"
